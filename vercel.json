{
  "version": 2,
  "cleanUrls": false,
  "trailingSlash": false,
  "routes": [
    { "src": "^/$", "dest": "/index.html" },
    { "src": "^/blog$", "dest": "/blog.html" },
    { "src": "^/ai-agent-indonesia-workflow$", "dest": "/blog.html" },
    { "src": "^/indonesia-ai-market-entry$", "dest": "/blog.html" },
    { "src": "^/ai-growth-china-to-indonesia$", "dest": "/blog.html" }
  ],
  "headers": [
    {
      "source": "/(.*).(css|js|svg|png|jpg|jpeg|webp|pdf)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
